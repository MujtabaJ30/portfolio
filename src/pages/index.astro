---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Mujtaba Jafri — Data Scientist, Product Manager, Data Analyst"
  description="Portfolio of Mujtaba Jafri. Data Scientist, Product Manager, and Data Analyst with a track record of shipping high-impact work."
>
  <section class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-[var(--color-ink)] mb-6" style="text-wrap: balance">
        Mujtaba Jafri
      </h1>
      <p class="text-lg md:text-xl text-[var(--color-muted)] mb-8 leading-relaxed max-w-2xl" style="text-wrap: pretty">
        Data Scientist, Product Manager, and Data Analyst who ships high-impact work across the stack. I build things that work and drive decisions that matter.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="#roles" class="px-5 py-2.5 text-sm font-medium rounded-lg bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-hover)] transition-colors no-underline">
          View my work
        </a>
        <a href="mailto:hello@mujtaba.dev" class="px-5 py-2.5 text-sm font-medium rounded-lg border border-[var(--color-border)] text-[var(--color-ink)] hover:bg-[var(--color-surface)] transition-colors no-underline">
          Get in touch
        </a>
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-6 py-16 border-t border-[var(--color-border)]">
    <div class="max-w-2xl">
      <h2 class="text-2xl font-bold text-[var(--color-ink)] mb-4">About</h2>
      <p class="text-[var(--color-muted)] leading-relaxed" style="text-wrap: pretty">
        I work at the intersection of data, product, and business. Whether I'm building ML models, defining product strategy, or uncovering insights through analysis, I focus on one thing: <strong class="text-[var(--color-ink)]">making things happen</strong>. I've shipped across multiple domains and roles, and I bring the same intensity to every problem.
      </p>
    </div>
  </section>

  <section id="roles" class="max-w-5xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-[var(--color-ink)] mb-10">Roles</h2>
    <div class="grid gap-6 md:grid-cols-3">
      <a href="/data-scientist" class="group block p-6 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)]/30 transition-all no-underline hover:-translate-y-0.5">
        <span class="inline-block px-2.5 py-1 text-xs font-medium rounded-md bg-[var(--color-primary)]/10 text-[var(--color-primary)] mb-4">
          Data Scientist
        </span>
        <h3 class="text-lg font-semibold text-[var(--color-ink)] mb-2 group-hover:text-[var(--color-primary)] transition-colors">
          ML pipelines &rarr;
        </h3>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">
          Building and deploying ML models that drive real decisions. From experimentation to production.
        </p>
      </a>
      <a href="/product-manager" class="group block p-6 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)]/30 transition-all no-underline hover:-translate-y-0.5">
        <span class="inline-block px-2.5 py-1 text-xs font-medium rounded-md bg-[var(--color-primary)]/10 text-[var(--color-primary)] mb-4">
          Product Manager
        </span>
        <h3 class="text-lg font-semibold text-[var(--color-ink)] mb-2 group-hover:text-[var(--color-primary)] transition-colors">
          Strategy &amp; delivery &rarr;
        </h3>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">
          Defining product strategy, shipping features, and driving outcomes through cross-functional teams.
        </p>
      </a>
      <a href="/data-analyst" class="group block p-6 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)]/30 transition-all no-underline hover:-translate-y-0.5">
        <span class="inline-block px-2.5 py-1 text-xs font-medium rounded-md bg-[var(--color-primary)]/10 text-[var(--color-primary)] mb-4">
          Data Analyst
        </span>
        <h3 class="text-lg font-semibold text-[var(--color-ink)] mb-2 group-hover:text-[var(--color-primary)] transition-colors">
          Insights &amp; dashboards &rarr;
        </h3>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed">
          Turning raw data into clear, actionable insights that drive business decisions.
        </p>
      </a>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-6 py-16 border-t border-[var(--color-border)]">
    <div class="max-w-xl">
      <h2 class="text-2xl font-bold text-[var(--color-ink)] mb-4">Get in touch</h2>
      <p class="text-[var(--color-muted)] mb-6 leading-relaxed">
        Looking for someone who can actually make things happen? Let's talk.
      </p>
      <a
        href="mailto:hello@mujtaba.dev"
        class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium rounded-lg bg-[var(--color-primary)] text-white hover:bg-[var(--color-primary-hover)] transition-colors no-underline"
      >
        hello@mujtaba.dev
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
