---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  role: string;
  tagline: string;
}

const { title, description, role, tagline } = Astro.props;
const canonical = `https://mujtaba.pages.dev/${role}`;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <section class="max-w-5xl mx-auto px-6 py-24 md:py-32">
    <div class="max-w-3xl">
      <span class="inline-block text-xs font-medium tracking-widest uppercase text-[var(--color-primary)] mb-4">
        {role}
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-[var(--color-ink)] mb-6" style="text-wrap: balance">
        {title}
      </h1>
      <p class="text-lg md:text-xl text-[var(--color-muted)] leading-relaxed max-w-2xl" style="text-wrap: pretty">
        {tagline}
      </p>
    </div>
  </section>

  <slot />
</BaseLayout>
