---
import type { Skill } from '../data/data-scientist';

export interface Props {
  skills: Skill[];
}
const { skills } = Astro.props;
---

<section class="max-w-5xl mx-auto px-6 py-16">
  <h2 class="text-2xl font-bold text-[var(--color-ink)] mb-10">Skills & Tools</h2>
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
    {skills.map((group) => (
      <div>
        <h3 class="text-xs font-semibold tracking-widest uppercase text-[var(--color-primary)] mb-4">
          {group.category}
        </h3>
        <ul class="space-y-2">
          {group.items.map((item) => (
            <li class="text-sm text-[var(--color-ink)]">{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
