---
import type { Experience } from '../data/data-scientist';

export interface Props {
  experience: Experience[];
}
const { experience } = Astro.props;
---

<section class="max-w-5xl mx-auto px-6 py-16">
  <h2 class="text-2xl font-bold text-[var(--color-ink)] mb-10">Experience</h2>
  <div class="space-y-8">
    {experience.map((exp) => (
      <div class="relative pl-6 border-l border-[var(--color-border)]">
        <div class="absolute left-0 top-1.5 w-2.5 h-2.5 -translate-x-1/2 rounded-full bg-[var(--color-primary)]" />
        <div class="mb-1 flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-3">
          <h3 class="text-base font-semibold text-[var(--color-ink)]">{exp.company}</h3>
          <span class="text-sm text-[var(--color-muted)]">{exp.role}</span>
        </div>
        <p class="text-xs font-mono text-[var(--color-muted)] mb-2">{exp.period}</p>
        <p class="text-sm text-[var(--color-muted)] leading-relaxed" style="text-wrap: pretty">
          {exp.description}
        </p>
      </div>
    ))}
  </div>
</section>
